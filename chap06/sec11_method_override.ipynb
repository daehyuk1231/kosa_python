   "source": [
    "from typing import override\n",
    "\n",
    "\n",
    "class Parent:\n",
    "    def method(self):\n",
    "        print(\"Parent.method() 실행:100줄\")\n",
    "        \n",
    "class Child(Parent):\n",
    "    @override\n",
    "    def method(self):\n",
    "        super().method()    # 100줄 재사용\n",
    "        print(\"Child.method() 실행:10줄\")\n",
    "        \n",
    "c = Child()\n",
    "c.method()"
   ]
  }
 ],
