   "source": [
    "# 함수 정의\n",
    "def sum(numbers: list[int]) -> int:\n",
    "    result: int = 0\n",
    "    while numbers:\n",
    "        result += numbers.pop()\n",
    "    return result\n",
    "\n",
    "# 함수 호출\n",
    "result = sum([10, 20, 30])\n",
    "print(result)"
   ]
  }
