   "source": [
    "def print_repeat(char: str, count: int) -> None:\n",
    "    while count:\n",
    "        print(char, end=\"\")\n",
    "        count -= 1\n",
    "        \n",
    "# 함수 호출\n",
    "print_repeat(\"a\", 5)"
   ]
  }
